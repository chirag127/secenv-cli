# SecEnv CLI environment variables
# These are optional overrides for advanced use. All have sensible defaults.
# See README.md for full usage.

# Git URL of the private vault repository. Required only for `secenv --init`.
# Example: git@github.com:chirag127/secenv-secrets.git
# SECENV_REPO_URL=

# Local directory where the vault is cloned. Defaults to ~/.secenv/secrets/.
# SECENV_LOCAL_DIR=

# Branch of the vault repo to use. Defaults to main.
# SECENV_BRANCH=main

# Path to the gh CLI binary if not on PATH. Optional.
# GH_BIN=/usr/local/bin/gh

# Git identity used by secenv for commits. Defaults to your global git config.
# SECENV_GIT_USER_NAME=SecEnv Bot
# SECENV_GIT_USER_EMAIL=secenv@localhost
